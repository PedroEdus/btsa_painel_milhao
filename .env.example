# Copie para .env (local). NUNCA commitar .env.

# Atualização: a base do Fabric atualiza às 8h e 15h (Brasília). Margem em
# minutos após o horário nominal p/ o pipeline terminar de gravar o snapshot
# (padrão 20 → painel busca às 8h20 e 15h20).
ATUALIZACAO_MARGEM_MINUTOS=20

# Service principal Azure AD (acesso ao OneLake / Fabric)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Regra de cupom (parâmetros pendentes de regulamento)
CUPOM_INCLUIR_CUSTAS=true
META_ARRECADACAO=0

# Auth restrita @btsa.com.br. false = painel aberto (padrão).
AUTH_ENABLED=false

# Opcional: parquet local no formato bronze (dev) — se setado, ignora OneLake
# SNAPSHOT_LOCAL=painel_milhao_snapshot.parquet
