# Copie para .env (local). NUNCA commitar .env.

# Fonte de dados: true = mock fiel ao contrato; false = OneLake Parquet
USE_MOCK=true
CACHE_TTL_SEGUNDOS=600

# Service principal Azure AD (acesso ao OneLake / Fabric)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Regra de cupom (parâmetros pendentes de regulamento)
CUPOM_INCLUIR_CUSTAS=true
META_ARRECADACAO=0

# Auth restrita @btsa.com.br. false = painel aberto (padrão).
AUTH_ENABLED=false
